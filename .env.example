# OpenAI (optional - enables LLM executive summary)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://your-custom-endpoint/v1

# Anthropic (used by evaluation comparison script)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini (used by evaluation comparison script)
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# CodeBERT checkpoint (optional - defaults shown)
# CODEBERT_CHECKPOINT_PATH=evaluation/llm_training/checkpoints/checkpoint_best.pt

# Paths
DOCKER_COMPOSE_PATH=docker/docker-compose.yml
ANALYSIS_STORAGE_PATH=backend/.analysis
