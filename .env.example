# OpenAI Configuration
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4o-mini

# Storage
ANALYSIS_STORAGE_PATH=backend/.analysis
SLITHER_COMPOSE_PATH=docker/docker-compose.yml

# Multi-Tool Configuration
ENABLE_SECURIFY=true
ENABLE_ECHIDNA=true
ENABLE_OYENTE=true

# Echidna Fuzzer Settings
ECHIDNA_TEST_LIMIT=50000
ECHIDNA_TIMEOUT=300

# Oyente Settings
OYENTE_TIMEOUT=180
